{
  "extends": "../gea/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@geajs/core",
    "paths": {
      "@geajs/core": ["../gea/src"],
      "@geajs/core/*": ["../gea/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
